{{! duplicate client script loading intentionally removed; header-scripts.hbs is canonical }}
<script>
;(function () {
  const SECTION_MAP = {
    article: { label: 'Articles', href: '/article/' },
    component: { label: 'Components', href: '/component/' },
    'quality-atlas': { label: 'Quality Atlas', href: '/quality-atlas/' },
    manifest: { label: 'Manifest', href: '/manifest/' },
    about: { label: 'About', href: '/about/' },
    owner: { label: 'Owner', href: '/owner/' },
    support: { label: 'Support', href: '/support/' },
    contact: { label: 'Contact', href: '/contact/' }
  }

  const buildHref = (siteRootPath, targetHref) => {
    if (!siteRootPath || siteRootPath === '.') {
      return targetHref
    }

    return `${siteRootPath.replace(/\/+$/, '')}${targetHref}`
  }

  const enhanceBreadcrumbs = () => {
    document.querySelectorAll('[data-owner-breadcrumbs]').forEach((node) => {
      const pageUrl = (node.dataset.pageUrl || '').replace(/^\/+/, '')
      if (!pageUrl || pageUrl === 'index.html') {
        return
      }

      const firstSegment = pageUrl.split('/')[0]
      const section = SECTION_MAP[firstSegment]
      if (!section) {
        return
      }

      if (pageUrl === `${firstSegment}/index.html`) {
        return
      }

      const itemNode = node.querySelector('[data-owner-breadcrumb-section]')
      const linkNode = node.querySelector('[data-owner-breadcrumb-section-link]')
      if (!itemNode || !linkNode) {
        return
      }

      linkNode.textContent = section.label
      linkNode.setAttribute('href', buildHref(node.dataset.siteRootPath || '.', section.href))
      itemNode.hidden = false
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', enhanceBreadcrumbs, { once: true })
    return
  }

  enhanceBreadcrumbs()
})()
</script>

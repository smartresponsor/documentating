{
  "policy": {
    "version": "1.0",
    "description": "Selection and cadence policy for Quality Atlas assessments.",
    "defaults": {
      "cadence_group": "every_2_days",
      "cooldown_hours": 24,
      "force_refresh_max_age_hours": 168,
      "branch": "master"
    },
    "cadence_groups": {
      "daily": {
        "min_interval_hours": 24,
        "requires_meaningful_change": true
      },
      "every_2_days": {
        "min_interval_hours": 48,
        "requires_meaningful_change": true
      },
      "weekly": {
        "min_interval_hours": 168,
        "requires_meaningful_change": false
      },
      "manual_only": {
        "min_interval_hours": 99999,
        "requires_meaningful_change": false
      }
    },
    "meaningful_path_prefixes": [
      "src/",
      "config/",
      "tests/",
      "migrations/",
      ".github/workflows/",
      "composer.json",
      "package.json",
      "Dockerfile",
      "docker/",
      ".deploy/",
      ".canonization/",
      ".cleanup/",
      ".commanding/",
      "openapi/",
      "nelmio/",
      ".sync/quality-atlas/contract/",
      ".sync/quality-atlas/cards/",
      ".sync/manifest/"
    ],
    "noise_path_prefixes": [
      "docs/article/",
      ".antora-src/",
      ".sync/quality-atlas/generated/assessment-runs/",
      ".sync/quality-atlas/generated/latest-assessment-summary.json",
      ".sync/quality-atlas/generated/selection-plan.json",
      ".sync/quality-atlas/generated/selection-plan-dataset.json",
      ".sync/quality-atlas/generated/portfolio-dataset.json",
      ".sync/quality-atlas/generated/internal-dataset.json"
    ],
    "milestone_tag_patterns": [
      "^v",
      "rc",
      "release"
    ],
    "component_overrides": {
      "documentating": {
        "cadence_group": "daily",
        "priority": 1
      },
      "accessing": {
        "cadence_group": "daily",
        "priority": 1
      }
    }
  },
